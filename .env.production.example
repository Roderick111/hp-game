# =============================================================================
# Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values
# This file is used by docker-compose.yml

# LLM Provider Configuration
DEFAULT_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model selection
DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4

# OpenRouter metadata (optional)
OR_SITE_URL=https://autror-academy.beautiful-apps.com
OR_APP_NAME=Auror Academy

# Fallback configuration
ENABLE_FALLBACK=true
FALLBACK_MODEL=openrouter/google/gemini-2.0-flash-001

# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# CORS (comma-separated origins for production)
CORS_ORIGINS=https://auror-academy.beautiful-apps.com
